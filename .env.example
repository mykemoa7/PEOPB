# Admin login + blog publishing. See README for how to generate these.

# bcrypt hash of your chosen admin password, base64-encoded (not the raw
# hash — its own "$" characters get corrupted by some .env loaders).
ADMIN_PASSWORD_HASH_B64=

# Any random long string, used to sign admin session cookies.
SESSION_SECRET=

# A GitHub Personal Access Token (fine-grained, "Contents: Read and write"
# on this one repo only) used to commit new blog posts.
GITHUB_TOKEN=

# "owner/repo" for this website's repository.
GITHUB_REPO=

# Defaults to "main" if unset.
GITHUB_BRANCH=main
