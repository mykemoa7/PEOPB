---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Admin" description="PEOPB admin" path="/admin">
	<section class="mx-auto max-w-[900px] px-6 pt-16 pb-10">
		<div class="flex items-center justify-between gap-4 mb-8">
			<h1 class="font-display text-2xl font-medium">Posts</h1>
			<div class="flex gap-3">
				<a
					href="/admin/posts/new"
					class="inline-flex items-center text-sm font-semibold rounded-md px-4 py-2 bg-ink text-fog hover:opacity-90 transition-opacity"
				>
					New post
				</a>
				<form method="POST" action="/api/admin/logout">
					<button
						type="submit"
						class="text-sm font-medium border border-line rounded-md px-4 py-2 hover:border-ink transition-colors"
					>
						Log out
					</button>
				</form>
			</div>
		</div>

		{posts.length === 0 ? (
			<p class="text-slate">No posts yet. Write your first one.</p>
		) : (
			<div class="flex flex-col gap-3">
				{posts.map((post) => (
					<div class="rounded-xl border border-line bg-surface p-5 flex items-center justify-between gap-4">
						<div>
							<div class="font-semibold text-sm mb-1">{post.data.title}</div>
							<div class="text-xs text-slate font-mono">
								{post.data.category} ·{" "}
								{post.data.pubDate.toLocaleDateString("en-GB", {
									day: "numeric",
									month: "long",
									year: "numeric",
								})}
							</div>
						</div>
						<span
							class={`text-[0.6875rem] font-mono uppercase tracking-wide rounded-full px-2 py-0.5 shrink-0 ${
								post.data.draft ? "text-brass bg-brass-tint" : "text-live bg-live-tint"
							}`}
						>
							{post.data.draft ? "Draft" : "Published"}
						</span>
					</div>
				))}
			</div>
		)}
	</section>
</Layout>
