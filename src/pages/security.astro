---
import LegalLayout from "../layouts/LegalLayout.astro";

export const prerender = true;
---

<LegalLayout
	title="Security"
	description="How PEOPB approaches security on peopb.com and across its products."
	path="/security"
	lastUpdated="July 10, 2026"
>
	<h2>This website</h2>
	<p>
		peopb.com is a static, informational site. It does not have user
		accounts, does not store form submissions on a server (the contact form
		opens your own email client instead), and is served over HTTPS.
	</p>

	<h2>Our products</h2>
	<p>
		Aseda Church Suite and its applications handle real member, attendance,
		and financial data, and are held to a higher bar than this website.
		Product-specific security details live with those products, not here.
	</p>

	<h2>Reporting a concern</h2>
	<p>
		If you believe you've found a security issue with peopb.com or any
		PEOPB product, tell us directly: <a href="mailto:peopbghana@gmail.com">peopbghana@gmail.com</a>.
		We don't have a formal bug bounty program at this stage, but we take
		reports seriously and will respond.
	</p>
</LegalLayout>
