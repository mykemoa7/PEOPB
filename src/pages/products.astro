---
import Layout from "../layouts/Layout.astro";

export const prerender = true;

const productLines = [
	{
		name: "Aseda Church Suite",
		copy: "The operating system for the modern church, membership, worship, finance, and community in one suite. Guanhwɛfo is the backbone every other application connects to, not one of five equal tiles.",
		status: "Live",
		statusClass: "text-live bg-live-tint",
		exploreUrl: "https://asedachurchsuite.com",
	},
	{
		name: "BillFlow",
		copy: "Invoicing, receipts, and estimates for African businesses, across construction, retail, food, health, and more.",
		status: "In development",
		statusClass: "text-brass bg-brass-tint",
	},
	{
		name: "PEOPB Studio",
		copy: "A new PEOPB product. Details are still being worked out.",
		status: "In development",
		statusClass: "text-brass bg-brass-tint",
	},
];
---

<Layout
	title="Products"
	description="PEOPB's products: Aseda Church Suite, live today, with BillFlow, PEOPB Studio, and more in development."
	path="/products"
>
	<section class="mx-auto max-w-[900px] px-6 pt-16 pb-10">
		<p class="font-mono text-xs uppercase tracking-wide text-brass font-semibold mb-4">
			Products
		</p>
		<h1 class="font-display text-4xl leading-[1.1] font-medium text-balance mb-4">
			One is live. More are on the way.
		</h1>
		<p class="text-lg text-slate max-w-[60ch]">
			Aseda Church Suite is live and in production today. BillFlow and PEOPB
			Studio are in development, named here honestly rather than launched
			ahead of proof. Other work is underway too, we'll name it here once
			there's something real to show for it.
		</p>
	</section>

	<section class="border-t border-line">
		<div class="mx-auto max-w-[900px] px-6 py-12 grid md:grid-cols-3 gap-4">
			{productLines.map((product) => (
				<div class="rounded-xl border border-line bg-surface p-6 flex flex-col">
					<div class="flex items-center gap-2 mb-2">
						<span class="font-semibold">{product.name}</span>
					</div>
					<span class={`inline-block self-start text-[0.6875rem] font-mono uppercase tracking-wide rounded-full px-2 py-0.5 mb-3 ${product.statusClass}`}>
						{product.status}
					</span>
					<p class="text-sm text-slate mb-4">{product.copy}</p>
					{product.exploreUrl && (
						<a
							href={product.exploreUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="mt-auto text-sm font-medium text-indigo"
						>
							Explore Aseda Church Suite ↗
						</a>
					)}
				</div>
			))}
		</div>
	</section>

	<section class="border-t border-line">
		<div class="mx-auto max-w-[900px] px-6 py-16 text-center">
			<h2 class="font-display text-2xl md:text-3xl font-medium mb-6 text-balance">
				Building something for your organization?
			</h2>
			<a
				href="/contact"
				class="inline-flex items-center text-sm font-semibold rounded-md px-5 py-2.5 bg-ink text-fog hover:opacity-90 transition-opacity"
			>
				Contact us
			</a>
		</div>
	</section>
</Layout>
