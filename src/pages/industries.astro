---
import Layout from "../layouts/Layout.astro";

export const prerender = true;

const upcoming = [
	{
		name: "Faith-adjacent institutions",
		copy: "Church-run schools, denominational NGOs, and mission organizations, sharing governance and membership patterns we already understand.",
	},
	{
		name: "Education",
		copy: "General schools, outside the church context, further out on the roadmap.",
	},
	{
		name: "Government",
		copy: "Digital services for government, gated behind our own corporate structure work first.",
	},
	{
		name: "Enterprise",
		copy: "General enterprise software, evaluated as demand and capacity allow.",
	},
];
---

<Layout
	title="Industries"
	description="PEOPB's proven industry is religious organizations, served by Aseda Church Suite. Other verticals are in development."
	path="/industries"
>
	<section class="mx-auto max-w-[900px] px-6 pt-16 pb-10">
		<p class="font-mono text-xs uppercase tracking-wide text-brass font-semibold mb-4">
			Industries
		</p>
		<h1 class="font-display text-4xl leading-[1.1] font-medium text-balance mb-4">
			One proven industry. A few more in motion.
		</h1>
		<p class="text-lg text-slate max-w-[60ch]">
			We'd rather tell you where we actually have evidence than pad this page
			with case studies that don't exist yet.
		</p>
	</section>

	<section class="border-t border-line">
		<div class="mx-auto max-w-[900px] px-6 py-12">
			<div class="rounded-xl border border-line bg-surface p-7 mb-3">
				<div class="flex items-center gap-2 mb-2">
					<span class="font-semibold text-lg">Religious Organizations</span>
					<span class="text-[0.6875rem] font-mono uppercase tracking-wide text-live bg-live-tint rounded-full px-2 py-0.5">
						Proven
					</span>
				</div>
				<p class="text-sm text-slate mb-3 max-w-[65ch]">
					Churches, ministries, and denominations run on Aseda Church Suite
					today: membership, worship, finance, and governance in one system.
				</p>
				<a href="/products#aseda-church-suite" class="text-sm font-medium text-indigo">
					See Aseda Church Suite →
				</a>
			</div>
		</div>
	</section>

	<section class="border-t border-line">
		<div class="mx-auto max-w-[900px] px-6 py-12">
			<h2 class="font-display text-xl font-medium mb-6">In development</h2>
			<div class="grid md:grid-cols-2 gap-4">
				{upcoming.map((item) => (
					<div class="rounded-xl border border-line bg-surface p-6 opacity-75">
						<div class="flex items-center gap-2 mb-2">
							<span class="font-semibold">{item.name}</span>
							<span class="text-[0.6875rem] font-mono uppercase tracking-wide text-brass bg-brass-tint rounded-full px-2 py-0.5">
								In development
							</span>
						</div>
						<p class="text-sm text-slate">{item.copy}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="border-t border-line">
		<div class="mx-auto max-w-[900px] px-6 py-16 text-center">
			<h2 class="font-display text-2xl md:text-3xl font-medium mb-6 text-balance">
				Don't see your industry yet?
			</h2>
			<a
				href="/contact"
				class="inline-flex items-center text-sm font-semibold rounded-md px-5 py-2.5 bg-ink text-fog hover:opacity-90 transition-opacity"
			>
				Tell us about it
			</a>
		</div>
	</section>
</Layout>
