---
import LegalLayout from "../layouts/LegalLayout.astro";

export const prerender = true;
---

<LegalLayout
	title="Cookies"
	description="peopb.com does not use cookies or tracking scripts."
	path="/cookies"
	lastUpdated="July 10, 2026"
>
	<h2>Short version</h2>
	<p>
		peopb.com does not set cookies and does not run analytics or tracking
		scripts. There's nothing to opt out of.
	</p>

	<h2>If that changes</h2>
	<p>
		If we ever add cookies or analytics to this site, we'll update this page
		first, before they go live, not after.
	</p>

	<h2>Contact</h2>
	<p>
		Questions: <a href="mailto:peopbghana@gmail.com">peopbghana@gmail.com</a>.
	</p>
</LegalLayout>
