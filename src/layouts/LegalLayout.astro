---
import Layout from "./Layout.astro";

interface Props {
	title: string;
	description: string;
	path: string;
	lastUpdated: string;
}

const { title, description, path, lastUpdated } = Astro.props;
---

<Layout title={title} description={description} path={path}>
	<section class="mx-auto max-w-[720px] px-6 pt-16 pb-10">
		<h1 class="font-display text-3xl font-medium mb-2">{title}</h1>
		<p class="font-mono text-xs text-slate">Last updated {lastUpdated}</p>
	</section>

	<section class="border-t border-line">
		<div class="mx-auto max-w-[720px] px-6 py-12 prose-legal">
			<slot />
		</div>
	</section>

	<section class="border-t border-line">
		<div class="mx-auto max-w-[720px] px-6 py-8">
			<div class="text-xs font-semibold uppercase tracking-wide text-slate mb-2">
				Registered business
			</div>
			<p class="font-mono text-sm">
				PEOPB SERVICES · Reg. BN059661220 · TIN P0028869559 · Kwabenya, Accra, Ghana
			</p>
		</div>
	</section>
</Layout>

<style>
	.prose-legal :global(h2) {
		font-family: var(--font-display);
		font-size: 1.25rem;
		font-weight: 500;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
	}
	.prose-legal :global(h2:first-child) {
		margin-top: 0;
	}
	.prose-legal :global(p) {
		color: var(--color-slate);
		margin-bottom: 1rem;
	}
	.prose-legal :global(ul) {
		color: var(--color-slate);
		margin-bottom: 1rem;
		padding-left: 1.25rem;
		list-style: disc;
	}
	.prose-legal :global(li) {
		margin-bottom: 0.4rem;
	}
	.prose-legal :global(a) {
		color: var(--color-teal);
	}
</style>
